# Copy this file to .env and fill in your own values:
#   cp .env.example .env
#
# Generate secrets with:
#   openssl rand -base64 32

DATABASE_URL=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Server authentication
HANDY_MASTER_SECRET=

# IMPORTANT: This MUST be a publicly accessible URL
# Use your domain name with HTTPS, or your public IP with port
HAPPY_SERVER_URL=
# For local testing without SSL:
# HAPPY_SERVER_URL=http://<your-ip>:3005

# S3/MinIO storage
S3_BUCKET=
S3_PUBLIC_URL=

# MinIO credentials
# SECURITY: Generate strong random credentials, don't use "minioadmin"
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
